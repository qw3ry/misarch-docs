{
    "name": "docs",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "docusaurus": "docusaurus",
        "start": "docusaurus start",
        "build": "docusaurus build",
        "swizzle": "docusaurus swizzle",
        "deploy": "docusaurus deploy",
        "clear": "docusaurus clear",
        "serve": "docusaurus serve",
        "write-translations": "docusaurus write-translations",
        "write-heading-ids": "docusaurus write-heading-ids",
        "format": "prettier --write \"**/*.{ts,json,js,tsx,jsx,md,mdx}\"",
        "format:check": "prettier --check \"**/*.{ts,json,js,tsx,jsx,md,mdx}\"",
        "render-diagrams": "node scripts/renderDiagrams.js"
    },
    "dependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@docusaurus/theme-mermaid": "^3.10.1",
        "@easyops-cn/docusaurus-search-local": "^0.55.1",
        "@graphql-markdown/diff": "^1.1.3",
        "@graphql-markdown/docusaurus": "^1.23.0",
        "@graphql-tools/graphql-file-loader": "^8.0.0",
        "@mdx-js/react": "^3.0.1",
        "@mermaid-js/mermaid-cli": "^11.15.0",
        "clsx": "^2.1.0",
        "dedent": "^1.5.1",
        "graphql-config": "^5.0.3",
        "mermaid": "^10.8.0",
        "photoswipe": "^5.4.3",
        "prism-react-renderer": "^2.3.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "rehype-katex": "^7.0.0",
        "remark-math": "^6.0.0"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "^3.10.1",
        "@hylimo/cli": "^1.1.2",
        "prettier": "^3.2.5"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "engines": {
        "node": ">=18.0"
    },
    "prettier": {
        "tabWidth": 4,
        "trailingComma": "none",
        "printWidth": 120,
        "overrides": [
            {
                "files": [
                    "*.md",
                    "*.mdx"
                ],
                "options": {
                    "tabWidth": 2
                }
            }
        ]
    }
}
